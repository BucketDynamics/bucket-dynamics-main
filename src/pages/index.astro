  </footer>

  <script>
    // ── Custom cursor ──
    const cursor = document.getElementById('cursor');
    const ring   = document.getElementById('cursorRing');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
    (function animateCursor() {
      cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
      rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12;
      ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
      requestAnimationFrame(animateCursor);
    })();
    document.querySelectorAll('a, button, input, textarea, select').forEach(el => {
      el.addEventListener('mouseenter', () => {
        ring.style.width = '60px'; ring.style.height = '60px';
        ring.style.borderColor = 'rgba(61,142,255,0.8)';
      });
      el.addEventListener('mouseleave', () => {
        ring.style.width = '36px'; ring.style.height = '36px';
        ring.style.borderColor = 'rgba(61,142,255,0.4)';
      });
    });

    // ── Scroll fade-in ──
    const observer = new IntersectionObserver(entries => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), i * 80);
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    // ── Rotor spin on hover ──
    document.querySelectorAll('.about-visual').forEach(el => {
      el.addEventListener('mouseenter', () => {
        el.querySelectorAll('circle[stroke-dasharray]').forEach(c => {
          c.style.animation = 'spin 2s linear infinite';
          c.style.transformOrigin = `${c.getAttribute('cx')}px ${c.getAttribute('cy')}px`;
        });
      });
      el.addEventListener('mouseleave', () => {
        el.querySelectorAll('circle[stroke-dasharray]').forEach(c => c.style.animation = '');
      });
    });

    // ── Form submit (Web3Forms) ──
    document.getElementById('submitBtn').addEventListener('click', async function () {
      const form = document.querySelector('.contact-form');
      const firstName = form.querySelectorAll('input[type=text]')[0].value.trim();
      const lastName  = form.querySelectorAll('input[type=text]')[1].value.trim();
      const email     = form.querySelector('input[type=email]').value.trim();
      const inquiry   = form.querySelector('select').value;
      const message   = form.querySelector('textarea').value.trim();

      if (!firstName || !lastName || !email || !inquiry || !message) {
        this.textContent = 'Please fill all fields';
        this.style.background = 'rgba(61,142,255,0.5)';
        setTimeout(() => { this.textContent = 'Send Message →'; this.style.background = ''; }, 3000);
        return;
      }

      this.textContent = 'Sending...';
      this.disabled = true;

      const data = new FormData();
      data.append('access_key', '88ed6b03-4d56-44e4-9fdc-395b70ff8a0f');
      data.append('name', firstName + ' ' + lastName);
      data.append('email', email);
      data.append('subject', 'Bucket Dynamics Inquiry: ' + inquiry);
      data.append('message', message);

      try {
        const res  = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: data });
        const json = await res.json();
        if (json.success) {
          this.textContent = 'Sent ✓';
          this.style.background = 'rgba(61,142,255,0.7)';
          form.querySelectorAll('input, textarea, select').forEach(el => el.value = '');
        } else {
          this.textContent = 'Error, try again';
          this.style.background = 'rgba(255,80,80,0.6)';
        }
      } catch (err) {
        this.textContent = 'Network error';
        this.style.background = 'rgba(255,80,80,0.6)';
      }

      this.disabled = false;
      setTimeout(() => { this.textContent = 'Send Message →'; this.style.background = ''; }, 4000);
    });

    // ── Mobile menu ──
    const menuBtn = document.getElementById('mobileMenuBtn');
    const mobileNav = document.getElementById('mobile-nav-overlay');
    menuBtn.addEventListener('click', () => {
      const isOpen = menuBtn.classList.toggle('open');
      mobileNav.classList.toggle('open', isOpen);
      mobileNav.setAttribute('aria-hidden', String(!isOpen));
    });
    window.closeMobileNav = () => {
      menuBtn.classList.remove('open');
      mobileNav.classList.remove('open');
      mobileNav.setAttribute('aria-hidden', 'true');
    };
  </script>

